# Supabase > Project Settings > API (or the Connect dialog)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Server-only. Never prefix this variable with NEXT_PUBLIC_.
OPENAI_API_KEY=

# Server-only Supabase secret key. Required only by the authenticated Vercel Cron.
SUPABASE_SECRET_KEY=

# Server-only random value used by Vercel to authenticate Cron requests.
CRON_SECRET=
VISUAL_SEARCH_DAILY_LIMIT=10

# Optional automated discovery provider. The subscribed plan must explicitly
# permit storing search results before setting the confirmation flag to true.
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_STORAGE_RIGHTS_CONFIRMED=false
